# Finalidade: variáveis de ambiente da aplicação (Versão Firestore).
APP_NAME=Sistema de Solicitações de Saldo
APP_ENV=development
APP_DEBUG=true
DEFAULT_TIMEZONE=America/Sao_Paulo
UPLOAD_TMP_DIR=./tmp/uploads
CSV_EXPORT_DIR=./tmp/exports

# Firebase/Firestore
FIREBASE_PROJECT_ID=seu-projeto-id
# Se estiver rodando fora do Cloud Run, precisa da chave JSON:
# GOOGLE_APPLICATION_CREDENTIALS=./chave-firebase.json
